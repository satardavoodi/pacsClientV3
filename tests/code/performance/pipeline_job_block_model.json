        {
          "id": "right_panel_series_info_schedule",
          "block_id": "block_1_data_services",
          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_panel/_hp_patient_open.py",
          "trigger": "patient open noncritical network tasks",
          "worker_model": "main loop task or deferred replay",
          "orphan_allowed": false,
          "notes": "schedule or defer right-panel and series info tasks"
        },
        {
          "id": "attachment_download_background",
          "block_id": "block_1_data_services",
          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_panel/_hp_patient_open.py",
