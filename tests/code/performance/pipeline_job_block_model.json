          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_download_service.py",
          "trigger": "download manager attached to widget",
          "worker_model": "Qt signal/slot fan-out",
          "orphan_allowed": false,
          "notes": "bridge DM progress and completion into patient widget"
        },
        {
          "id": "server_series_info_push",
          "block_id": "block_1_data_services",
          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_panel/_hp_patient_open.py",
          "trigger": "study info available",
          "worker_model": "main thread + background fetch fallback",
          "orphan_allowed": false,
          "notes": "push series info into widget / thumbnail overview"
