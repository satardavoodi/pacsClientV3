{
  "version": "2026-04-17",
  "purpose": "Explicit ownership map for pipeline jobs involved in opening a new patient and stack/scroll image interaction. No listed job may remain orphaned.",
  "blocks": {
    "block_1_data_services": {
      "label": "Block 1 - Data services"
    },
    "block_2_viewer_hot_path": {
      "label": "Block 2 - Viewer hot path"
    },
    "block_3_cache_scroll_orchestration": {
      "label": "Block 3 - Cache, scroll, orchestration"
    }
  },
  "scenarios": [
    {
      "id": "open_new_patient",
      "label": "Open new patient",
      "jobs": [
        {
          "id": "open_request_guard",
          "block_id": "block_1_data_services",
          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_panel/_hp_patient_open.py",
          "trigger": "patient table double-click",
          "worker_model": "main thread async entry",
          "orphan_allowed": false,
          "notes": "duplicate-open guard and existing-tab fast focus"
        },
        {
          "id": "study_path_resolution",
          "block_id": "block_1_data_services",
          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_panel/_hp_patient_open.py",
          "trigger": "patient open",
          "worker_model": "main thread + background sync helper",
          "orphan_allowed": false,
          "notes": "resolve output folder and offline-cloud sync path"
        },
        {
          "id": "tab_create_activate",
          "block_id": "block_1_data_services",
          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_panel/_hp_patient_open.py",
          "trigger": "patient open hot path",
          "worker_model": "main thread",
          "orphan_allowed": false,
          "notes": "create patient tab and activate it immediately"
        },
        {
          "id": "download_manager_start_priority",
          "block_id": "block_1_data_services",
          "owner_file": "PacsClient/pacs/workstation_ui/home_ui/home_panel/_hp_patient_open.py",
          "trigger": "server-backed patient open",
          "worker_model": "download manager subprocess path",
          "orphan_allowed": false,
          "notes": "start High-priority study download on patient open"
