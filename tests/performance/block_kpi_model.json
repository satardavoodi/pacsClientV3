{
  "version": "2026-04-27",
  "purpose": "Unified viewer performance KPIs grouped by shared Block A infrastructure and mode-specific Block B/C viewer ownership.",
  "blocks": [
    {
      "id": "block_1_data_services",
      "label": "Block A - Shared data services",
      "applies_to": ["FAST_QT", "FAST_LAZY_VTK", "Advanced"],
      "role": "Shared download, thumbnail, server, socket/gRPC, DICOM/header persistence, DB/storage writes, logs, and progress state.",
      "position": "Mode-neutral upstream producer feeding FAST and Advanced through the same support path.",
      "preferred_worker_model": {
        "main_process": "Orchestrator decisions and lightweight UI projection only.",
        "background": [
          "download subprocesses",
          "database/storage background work",
          "thumbnail background work",
          "bounded log queue/listener"
        ],
        "rule": "Do not duplicate DB, disk, server, or download paths per viewer mode."
      },
      "metrics": [
        {
          "key": "cpu_p95_pct",
          "label": "CPU p95",
          "goal": "<80 primary overlap target; <50 stretch",
          "source": "process_summary",
          "status": "existing"
        },
        {
          "key": "thread_count_p95",
          "label": "Thread count p95",
          "goal": "Stable; detect worker explosion during overlap",
          "source": "process_summary",
          "status": "existing"
        },
        {
          "key": "read_mb_delta",
